generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// Comando: npx prisma db push - para criar a tabela no banco de dados
// Comando: npx prisma dv pull- para atualizar o schema prisma com as tabelas do banco de dados
model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  status Boolean @default(true)
  role Role @default(USER)
  createdAt DateTime @default(now())
  updated DateTime @updatedAt
  posts Post[]
  
}

model Post {
  id Int @id @default(autoincrement())
  title String
  subtitle String?
  content String
  userId Int
  user User @relation(fields: [userId], references: [id])
}
